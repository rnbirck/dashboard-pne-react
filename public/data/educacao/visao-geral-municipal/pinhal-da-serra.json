      "title": "Taxas de Rendimento Escolar",
      "referenceYear": 2025,
      "url": "https://www.gov.br/inep/pt-br/acesso-a-informacao/dados-abertos/indicadores-educacionais/taxas-de-rendimento-escolar"
    }

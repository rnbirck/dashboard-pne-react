{
  "name": "dashboard-pne-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ui": "vite --config vite.dev-ui.config.ts",
    "build": "vite build",
    "check:units": "node scripts/checks/verify-units.cjs",
    "check:state-reference": "python -m unittest discover -s data_pipeline/tests -p \"test_*.py\"",
    "check:state-json": "node scripts/checks/verify-state-reference.cjs",
    "check:state-json:closed": "node scripts/checks/verify-state-reference.cjs public/data/pne_2014_2024/referencia_estadual.json",
    "lint": "eslint .",
    "list:indicators": "node scripts/checks/list-indicators.cjs",
    "preview": "vite preview",
    "test:app-routing": "node scripts/checks/app-routing-test.mjs",
    "test:pne-cycle": "node --test scripts/checks/pne-accumulative-cycle.test.mjs",
    "test:diagnostic": "node --test scripts/checks/diagnostic-contract.test.mjs",
    "test:municipal-finance": "node --test scripts/checks/municipal-finance-p5b1.test.mjs scripts/checks/municipal-finance-p5c1.test.mjs",
    "test:education": "node scripts/checks/education-test.mjs",
    "test:dev-ui": "node scripts/checks/dev-ui-test.mjs && node --test scripts/checks/dev-ui-visual-core.test.mjs && node scripts/checks/ui-architecture-test.mjs",
    "test:ui-architecture": "node scripts/checks/ui-architecture-test.mjs",
    "test:dev-ui:visual": "node scripts/checks/dev-ui-visual-test.mjs",
    "test:dev-ui:visual:update": "node scripts/checks/dev-ui-visual-test.mjs --update",
    "test:e2e": "node scripts/checks/e2e-test.cjs",
    "test:e2e:diagnostic": "node scripts/checks/diagnostic-e2e-test.cjs",
    "test:e2e:municipal-finance": "node scripts/checks/municipal-finance-e2e-test.cjs",
    "test:visual": "node scripts/checks/visual-test.cjs",
    "update:visual": "node -e \"process.env.UPDATE_VISUAL_BASELINES='1';require('./scripts/checks/visual-test.cjs')\"",
    "update:data": "python data_pipeline/scripts/update_static_data.py",
    "update:data:skip-build": "python data_pipeline/scripts/update_static_data.py --skip-build",
    "verify:indicator": "python data_pipeline/scripts/export_static_data.py",
    "validate:details": "python data_pipeline/scripts/validate_static_details.py",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/public-sans": "^5.2.7",
    "@fontsource/source-serif-4": "^5.2.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "agentation": "^3.0.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "^8.0.12"
  }
}

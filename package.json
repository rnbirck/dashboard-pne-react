{
  "name": "dashboard-pne-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "check:state-json": "node scripts/checks/verify-state-reference.cjs",
    "check:state-json:closed": "node scripts/checks/verify-state-reference.cjs public/data/pne_2014_2024/referencia_estadual.json",
    "list:indicators": "node scripts/checks/list-indicators.cjs",
    "test:app-routing": "node scripts/checks/app-routing-test.mjs",
    "test:data-sources": "node scripts/checks/verify-data-source-notes.cjs",
    "test:pne-cycle": "node --test scripts/checks/pne-accumulative-cycle.test.mjs",
    "test:diagnostic": "node --test scripts/checks/diagnostic-contract.test.mjs",
    "test:municipal-finance": "node --test --test-concurrency=1 scripts/checks/financial-final-dgf5f.test.mjs scripts/checks/municipal-finance-p5b1.test.mjs scripts/checks/qse-annual.test.mjs",
    "test:education": "node scripts/checks/education-test.mjs",
    "test:ui-architecture": "node scripts/checks/ui-architecture-test.mjs",
    "check:hygiene": "node scripts/checks/repository-hygiene-test.mjs",
    "test:unit": "node --test --test-concurrency=1 scripts/checks/diagnostic-contract.test.mjs scripts/checks/financial-final-dgf5f.test.mjs scripts/checks/municipal-finance-p5b1.test.mjs scripts/checks/pne-accumulative-cycle.test.mjs scripts/checks/pne-chart-system.test.mjs scripts/checks/qse-annual.test.mjs",
    "test:python": "python -m unittest discover -s data_pipeline/tests -p \"test_*.py\"",
    "test:e2e": "node scripts/checks/current-platform-e2e-test.cjs",
    "generate:diagnostic-catalog": "node scripts/generate-diagnostic-catalog.mjs",
    "update:education-data": "python data_pipeline/scripts/update_static_data.py --education-only",
    "update:data": "python data_pipeline/scripts/update_static_data.py",
    "update:data:skip-build": "python data_pipeline/scripts/update_static_data.py --skip-build",
    "verify:indicator": "python data_pipeline/scripts/export_static_data.py",
    "validate:details": "python data_pipeline/scripts/validate_static_details.py"
  },
  "dependencies": {
    "@fontsource/public-sans": "^5.2.7",
    "@fontsource/source-serif-4": "^5.2.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "^8.0.12"
  }
}
